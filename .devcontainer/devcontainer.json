{
  "name": "Solo-Leveled Dev Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/Solo-Leveled",
  "postCreateCommand": "bash /workspaces/Solo-Leveled/.devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "cweijan.vscode-mysql-client2"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/miniconda/envs/soloenv/bin/python"
      }
    }
  }
}
